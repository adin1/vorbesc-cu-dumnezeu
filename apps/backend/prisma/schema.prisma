generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String
  name              String
  role              String               @default("USER")
  denomination      String               @default("GENERAL")
  dailyStreak       Int                  @default(0)
  notifyDaily       Boolean              @default(true)
  notifyCommunity   Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  spiritualPreference SpiritualPreference?
  chatSessions      ChatSession[]
  prayers           Prayer[]
  journalEntries    JournalEntry[]
  userPlanProgress  UserPlanProgress[]
  favoriteVerses    FavoriteVerse[]
  prayerRequests    PrayerRequest[]
  prayerSupports    PrayerSupport[]
  notifications     Notification[]
  gdprRequests      GdprRequest[]
  subscriptions     UserSubscription[]
  donations         Donation[]
  acquisitions      UserAcquisition[]
  socialActivities  SocialActivityLog[]
}

model SpiritualMood {
  id        String      @id @default(cuid())
  slug      String      @unique
  name      String      @unique
  createdAt DateTime    @default(now())
  guides    MoodGuide[]
}

model MoodGuide {
  id                 String        @id @default(cuid())
  moodId             String
  warmMessage        String
  verse              String
  shortPrayer        String
  reflectionQuestion String
  createdAt          DateTime      @default(now())
  mood               SpiritualMood @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([moodId])
}

model Verse {
  id        String    @id @default(cuid())
  reference String
  text      String
  topic     String
  createdAt DateTime  @default(now())
}

model EncouragementMessage {
  id        String    @id @default(cuid())
  topic     String
  message   String
  createdAt DateTime  @default(now())
}

model SpiritualPreference {
  id                String        @id @default(cuid())
  userId            String        @unique
  preferredTone     String        @default("GENTLE")
  spiritualGoal     String
  confession        String        @default("GENERAL")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ChatSession {
  id           String        @id @default(cuid())
  userId       String
  title        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  role         String
  content      String
  createdAt    DateTime    @default(now())
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model PrayerCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  prayers   Prayer[]
  createdAt DateTime  @default(now())
}

model Prayer {
  id          String          @id @default(cuid())
  userId      String?
  categoryId  String
  title       String
  bibleVerse  String?
  bibleReference String?
  shortReflection String?
  content     String
  isGenerated Boolean         @default(false)
  isPremium   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  category    PrayerCategory  @relation(fields: [categoryId], references: [id])
}

model JournalEntry {
  id          String    @id @default(cuid())
  userId      String
  mood        String
  burden      String
  gratitude   String
  prayerToday String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
}

model SpiritualPlan {
  id           String            @id @default(cuid())
  title        String
  description  String
  durationDays Int
  isPremium    Boolean           @default(false)
  premiumTier  String?
  createdAt    DateTime          @default(now())
  days         SpiritualPlanDay[]
  progress     UserPlanProgress[]
}

model SpiritualPlanDay {
  id                 String         @id @default(cuid())
  spiritualPlanId    String
  dayNumber          Int
  title              String
  verse              String
  explanation        String
  prayer             String
  reflectionQuestion String
  spiritualPlan      SpiritualPlan  @relation(fields: [spiritualPlanId], references: [id], onDelete: Cascade)

  @@unique([spiritualPlanId, dayNumber])
}

model UserPlanProgress {
  id         String         @id @default(cuid())
  userId     String
  planId     String
  dayNumber  Int            @default(1)
  completed  Boolean        @default(false)
  startedAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       SpiritualPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model FavoriteVerse {
  id        String    @id @default(cuid())
  userId    String
  reference String
  text      String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrayerRequest {
  id             String              @id @default(cuid())
  userId         String
  content        String
  anonymous      Boolean             @default(true)
  shareTarget    String              @default("APP_ONLY")
  facebookShareText String?
  status         String              @default("PENDING")
  moderationNote String?
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  supports       PrayerSupport[]
}

model PrayerSupport {
  id              String        @id @default(cuid())
  userId          String
  prayerRequestId String
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayerRequest   PrayerRequest @relation(fields: [prayerRequestId], references: [id], onDelete: Cascade)

  @@unique([userId, prayerRequestId])
  @@map("prayer_supports")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GdprRequest {
  id         String            @id @default(cuid())
  userId     String
  type       String
  status     String            @default("PENDING")
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  description       String
  priceMonthly      Int
  stripePriceId     String?
  features          String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  subscriptions     UserSubscription[]
}

model UserSubscription {
  id                     String             @id @default(cuid())
  userId                 String
  planId                 String
  status                 String             @default("ACTIVE")
  startedAt              DateTime           @default(now())
  expiresAt              DateTime?
  provider               String
  providerSubscriptionId String?            @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
}

model Donation {
  id                String    @id @default(cuid())
  userId            String?
  amount            Int
  currency          String    @default("RON")
  provider          String
  providerPaymentId String?
  message           String?
  createdAt         DateTime  @default(now())
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model PremiumFeature {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  createdAt   DateTime @default(now())
}

model UserAcquisition {
  id          String   @id @default(cuid())
  userId      String?
  source      String
  medium      String?
  campaign    String?
  landingPage String?
  referrer    String?
  firstVisitAt DateTime
  convertedAt DateTime?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([source, createdAt])
  @@index([userId])
}

model SocialActivityLog {
  id        String   @id @default(cuid())
  platform  String
  type      String
  campaign  String?
  source    String?
  metadata  String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([platform, createdAt])
  @@index([type, createdAt])
  @@index([userId])
}
