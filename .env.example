# Shared
NODE_ENV=development
JWT_SECRET="change-me-in-production"
DASHBOARD_CACHE_ADMIN_EMAIL="admin@example.com"
DASHBOARD_CACHE_OP_WINDOW_MS=60000
DASHBOARD_CACHE_OP_MAX_REQUESTS=8
FRONTEND_URL="http://localhost:3000"

# Backend
PORT=3001
DATABASE_URL="file:./dev.db"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_ENABLE_DASHBOARD_DIAGNOSTICS="false"
NEXT_PUBLIC_FACEBOOK_GROUP_URL=""
NEXT_PUBLIC_APP_URL="https://vorbeste-cu-dumnezeu.vercel.app"
NEXT_PUBLIC_APP_PUBLIC_URL="https://vorbeste-cu-dumnezeu.vercel.app"
NEXT_PUBLIC_PRIVACY_URL="https://vorbeste-cu-dumnezeu.vercel.app/privacy-policy"
NEXT_PUBLIC_TERMS_URL="https://vorbeste-cu-dumnezeu.vercel.app/terms"
NEXT_PUBLIC_DISCLAIMER_URL="https://vorbeste-cu-dumnezeu.vercel.app/disclaimer"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe backend
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Payment provider switch (STRIPE or LEMONSQUEEZY)
PAYMENT_PROVIDER="STRIPE"

# Lemon Squeezy backend
LEMONSQUEEZY_WEBHOOK_SECRET=""

# Lemon Squeezy checkout URLs (direct links from dashboard)
LEMONSQUEEZY_CHECKOUT_URL_PREMIUM_BASIC=""
LEMONSQUEEZY_CHECKOUT_URL_PREMIUM_FAMILY=""
LEMONSQUEEZY_CHECKOUT_URL_DONATION_500=""
LEMONSQUEEZY_CHECKOUT_URL_DONATION_1000=""
LEMONSQUEEZY_CHECKOUT_URL_DONATION_2500=""
LEMONSQUEEZY_CHECKOUT_URL_DONATION_5000=""
