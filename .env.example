# Backend
PORT=3001
DATABASE_URL="file:./dev.db"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_ENABLE_DASHBOARD_DIAGNOSTICS="false"
